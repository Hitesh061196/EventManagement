@model CreateEventManagerViewModel
@{
    ViewData["Title"] = "Manage Event Managers";
}

<section class="surface-card p-4 p-lg-5">
    <div class="page-title-row">
        <div>
            <h1 class="section-title">Event Manager Creation</h1>
            <p class="section-copy">Create event manager and event planner staff accounts. Login credentials are generated automatically and stored against the account for distribution.</p>
        </div>
    </div>

    <form asp-action="CreateEventManager" method="post" class="row g-3 mb-5">
        @Html.AntiForgeryToken()
        <div class="col-md-4">
            <label class="form-label">First Name</label>
            <input asp-for="FirstName" class="form-control" />
        </div>
        <div class="col-md-4">
            <label class="form-label">Middle Name</label>
            <input asp-for="MiddleName" class="form-control" />
        </div>
        <div class="col-md-4">
            <label class="form-label">Last Name</label>
            <input asp-for="LastName" class="form-control" />
        </div>
        <div class="col-md-4">
            <label class="form-label">Email</label>
            <input asp-for="Email" class="form-control" />
        </div>
        <div class="col-md-4">
            <label class="form-label">Contact No</label>
            <input asp-for="ContactNo" class="form-control" />
        </div>
        <div class="col-md-4">
            <label class="form-label d-block">Gender</label>
            <div class="d-flex gap-4 mt-1">
                <div class="form-check">
                    <input class="form-check-input" type="radio" asp-for="Gender" id="emGenderMale" value="Male" />
                    <label class="form-check-label" for="emGenderMale">Male</label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="radio" asp-for="Gender" id="emGenderFemale" value="Female" />
                    <label class="form-check-label" for="emGenderFemale">Female</label>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <label class="form-label">State</label>
            <select asp-for="StateId" id="emStateSelect" class="form-select">
                <option value="0">-- Select State --</option>
                @foreach (var state in Model.States)
                {
                    <option value="@state.State_Id">@state.State_Name</option>
                }
            </select>
        </div>
        <div class="col-md-4">
            <label class="form-label">City</label>
            <select asp-for="CityId" id="emCitySelect" class="form-select">
                <option value="0">-- Select City --</option>
            </select>
        </div>
        <div class="col-md-4">
            <label class="form-label">Area</label>
            <select asp-for="AreaId" id="emAreaSelect" class="form-select">
                <option value="0">-- Select Area --</option>
                @foreach (var area in Model.Areas)
                {
                    <option value="@area.Area_Id">@area.Area_Name, @area.City?.City_Name</option>
                }
            </select>
        </div>
        <div class="col-md-8">
            <label class="form-label">Address</label>
            <input asp-for="Address" class="form-control" />
        </div>
        <div class="col-md-4">
            <label class="form-label">Role</label>
            <select asp-for="RoleName" class="form-select">
                @foreach (var role in Model.AvailableRoles)
                {
                    <option value="@role.Roll_Name">@role.Roll_Name</option>
                }
            </select>
        </div>
        <div class="col-12">
            <button type="submit" class="btn btn-brand">Create Staff Account</button>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table table-modern align-middle">
            <thead><tr><th>Name</th><th>Email</th><th>Role</th><th>Area</th></tr></thead>
            <tbody>
            @foreach (var staff in Model.ExistingStaff)
            {
                <tr>
                    <td>@staff.First_Name @staff.Middle_Name @staff.Last_Name</td>
                    <td>@staff.Email_Id</td>
                    <td>@staff.Login?.Roll?.Roll_Name</td>
                    <td>@staff.Area?.Area_Name, @staff.Area?.City?.City_Name</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>

@section Scripts {
    <script>
        (() => {
            const stateSelect = document.getElementById("emStateSelect");
            const citySelect = document.getElementById("emCitySelect");
            const areaSelect = document.getElementById("emAreaSelect");

            const resetSelect = (sel, placeholder) => {
                sel.innerHTML = `<option value="0">${placeholder}</option>`;
            };

            stateSelect.addEventListener("change", async () => {
                resetSelect(citySelect, "-- Select City --");
                resetSelect(areaSelect, "-- Select Area --");
                const stateId = stateSelect.value;
                if (!stateId || stateId === "0") return;
                const res = await fetch(`/Account/GetCitiesByState?stateId=${stateId}`);
                const cities = await res.json();
                cities.forEach(c => {
                    const opt = document.createElement("option");
                    opt.value = c.city_Id;
                    opt.textContent = c.city_Name;
                    citySelect.appendChild(opt);
                });
            });

            citySelect.addEventListener("change", async () => {
                resetSelect(areaSelect, "-- Select Area --");
                const cityId = citySelect.value;
                if (!cityId || cityId === "0") return;
                const res = await fetch(`/Account/GetAreasByCity?cityId=${cityId}`);
                const areas = await res.json();
                areas.forEach(a => {
                    const opt = document.createElement("option");
                    opt.value = a.area_Id;
                    opt.textContent = a.area_Name;
                    areaSelect.appendChild(opt);
                });
            });
        })();
    </script>
}
