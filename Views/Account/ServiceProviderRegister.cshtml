@{
    ViewData["Title"] = "Service Provider Register";
    var states = ViewBag.States as List<StateMaster> ?? new();
}

<div class="row justify-content-center">
    <div class="col-xl-8">
        <section class="surface-card p-4 p-lg-5">
            <h1 class="section-title mb-2">Service Person Registration</h1>
            <p class="section-copy mb-4">This registration goes into admin approval. Once approved, the generated password is sent through a mail simulation stored in the system.</p>

            <form method="post" class="row g-3">
                @Html.AntiForgeryToken()
                <div class="col-md-6">
                    <label class="form-label">Service Provider Name</label>
                    <input name="providerName" class="form-control" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Email</label>
                    <input name="email" type="email" class="form-control" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Mobile No.</label>
                    <input name="mobileNo" class="form-control" maxlength="15" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Shop Name</label>
                    <input name="shopName" class="form-control" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label d-block">Gender</label>
                    <div class="d-flex gap-4 mt-1">
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="gender" id="spGenderMale" value="Male" checked required />
                            <label class="form-check-label" for="spGenderMale">Male</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="gender" id="spGenderFemale" value="Female" />
                            <label class="form-check-label" for="spGenderFemale">Female</label>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <label class="form-label">Service Type</label>
                    <select name="serviceType" class="form-select" required>
                        <option>Party Plot</option>
                        <option>Caterer</option>
                        <option>Decoration</option>
                        <option>Music</option>
                        <option>Transporter</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">State</label>
                    <select name="stateId" id="spStateSelect" class="form-select" required>
                        <option value="">-- Select State --</option>
                        @foreach (var state in states)
                        {
                            <option value="@state.State_Id">@state.State_Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">City</label>
                    <select name="cityId" id="spCitySelect" class="form-select" required>
                        <option value="">-- Select City --</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Area</label>
                    <select name="areaId" id="spAreaSelect" class="form-select" required>
                        <option value="">-- Select Area --</option>
                    </select>
                </div>
                <div class="col-12">
                    <label class="form-label">Address</label>
                    <textarea name="address" class="form-control" rows="2" required></textarea>
                </div>
                <div class="col-md-12">
                    <label class="form-label">Profile Image Url</label>
                    <input name="profileImageUrl" class="form-control" placeholder="https://..." />
                </div>
                <div class="col-12">
                    <label class="form-label">Description</label>
                    <textarea name="description" class="form-control" rows="3" required></textarea>
                </div>
                <div class="col-12">
                    <button type="submit" class="btn btn-brand">Submit For Approval</button>
                </div>
            </form>
        </section>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const stateSelect = document.getElementById("spStateSelect");
            const citySelect = document.getElementById("spCitySelect");
            const areaSelect = document.getElementById("spAreaSelect");

            const resetSelect = (sel, placeholder) => {
                sel.innerHTML = `<option value="">${placeholder}</option>`;
            };

            stateSelect.addEventListener("change", async () => {
                resetSelect(citySelect, "-- Select City --");
                resetSelect(areaSelect, "-- Select Area --");
                const stateId = stateSelect.value;
                if (!stateId) return;
                const res = await fetch(`/Account/GetCitiesByState?stateId=${stateId}`);
                const cities = await res.json();
                cities.forEach(c => {
                    const opt = document.createElement("option");
                    opt.value = c.city_Id;
                    opt.textContent = c.city_Name;
                    citySelect.appendChild(opt);
                });
            });

            citySelect.addEventListener("change", async () => {
                resetSelect(areaSelect, "-- Select Area --");
                const cityId = citySelect.value;
                if (!cityId) return;
                const res = await fetch(`/Account/GetAreasByCity?cityId=${cityId}`);
                const areas = await res.json();
                areas.forEach(a => {
                    const opt = document.createElement("option");
                    opt.value = a.area_Id;
                    opt.textContent = a.area_Name;
                    areaSelect.appendChild(opt);
                });
            });
        })();
    </script>
}
