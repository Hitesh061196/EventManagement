@{
    ViewData["Title"] = "About";
}

<section class="surface-card p-4 p-lg-5">
    <div class="page-title-row">
        <div>
            <h1 class="section-title">Visitor About Us Page</h1>
            <p class="section-copy">This project showcases a complete event management process across visitor inquiry, customer booking, provider execution, event-manager approval, and admin control.</p>
        </div>
    </div>
    <div class="row g-4">
        <div class="col-lg-4">
            <div class="metric-card p-4 h-100">
                <h5 class="fw-bold">Visitor</h5>
                <p class="text-secondary mb-0">Browse event types, learn about the platform, and submit inquiries before registration.</p>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="metric-card p-4 h-100">
                <h5 class="fw-bold">Customer</h5>
                <p class="text-secondary mb-0">Register, login, select services step by step, pay, track event status, and submit feedback.</p>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="metric-card p-4 h-100">
                <h5 class="fw-bold">Operations</h5>
                <p class="text-secondary mb-0">Service providers manage orders and statuses, event managers confirm orders, and admin oversees the full system.</p>
            </div>
        </div>
    </div>
</section>
