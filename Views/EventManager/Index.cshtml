@model EventManagerDashboardViewModel
@{
    ViewData["Title"] = "Event Manager Dashboard";
}

<section class="surface-card p-4 p-lg-5">
    <div class="page-title-row">
        <div>
            <h1 class="section-title">Login Event Manager and View Order</h1>
            <p class="section-copy">The event manager can review service confirmations, event progress, and confirm the customer order.</p>
        </div>
    </div>

    <div class="row g-4">
        @foreach (var booking in Model.Bookings)
        {
            <div class="col-12">
                <div class="timeline-card p-4">
                    <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 mb-3">
                        <div>
                            <h4 class="fw-bold mb-1">@booking.Booking_Reference</h4>
                            <div class="small text-secondary">@booking.Customer?.First_Name @booking.Customer?.Last_Name • @booking.EventType?.Event_Type • @booking.Date.ToString("dd MMM yyyy")</div>
                        </div>
                        <div class="text-lg-end">
                            <div class="price-pill mb-2">@booking.Ammount.ToString("C0")</div>
                            @{
                                var statusPillCss = booking.Event_Manager_Approved ? "success"
                                    : booking.Booking_Status == AppConstants.BookingStatus.RejectedByManager ? "danger"
                                    : "warning";
                            }
                            <div class="status-pill @statusPillCss">@booking.Booking_Status</div>
                        </div>
                    </div>

                    <div class="row g-3 mb-4">
                        @foreach (var service in booking.Services)
                        {
                            <div class="col-md-6 col-xl-4">
                                <div class="metric-card p-3 h-100">
                                    <div class="d-flex justify-content-between mb-2">
                                        <span class="fw-semibold">@service.Service_Category</span>
                                        <span class="status-pill @(service.Confirmation_Status == "Confirmed" ? "success" : "warning")">@service.Confirmation_Status</span>
                                    </div>
                                    <div class="small text-secondary">@(service.ServiceCatalogItem?.Service_Name ?? "Service")</div>
                                    <div class="small text-secondary">@(service.ServiceCatalogItem?.ServiceProvider?.Service_Provider_Name ?? string.Empty)</div>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="row g-3 mb-4">
                        @foreach (var status in booking.StatusUpdates.OrderByDescending(s => s.Date))
                        {
                            <div class="col-md-6">
                                <div class="metric-card p-3 h-100">
                                    <div class="status-pill success mb-2">@status.Event_Type</div>
                                    <div class="fw-semibold">@status.Description</div>
                                    <div class="small text-secondary">@status.Date.ToLocalTime().ToString("dd MMM yyyy hh:mm tt")</div>
                                </div>
                            </div>
                        }
                    </div>

                    @if (booking.Booking_Status == AppConstants.BookingStatus.RejectedByManager)
                    {
                        <div class="d-flex align-items-center gap-3 flex-wrap">
                            <span class="status-pill danger"><i class="bi bi-x-circle-fill me-1"></i>Rejected by Event Manager</span>
                            @if (!string.IsNullOrEmpty(booking.Rejection_Reason))
                            {
                                <span class="small text-secondary">Reason: @booking.Rejection_Reason</span>
                            }
                        </div>
                    }
                    else if (!booking.Event_Manager_Approved && Context.Session.GetString("Role") == AppConstants.Roles.EventManager)
                    {
                        <div class="d-flex gap-2 flex-wrap">
                            <form asp-action="ConfirmOrder" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@booking.Booking_Id" />
                                <button class="btn btn-brand">Confirm Order</button>
                            </form>
                            <button type="button" class="btn btn-outline-danger"
                                    data-bs-toggle="modal" data-bs-target="#rejectModal-@booking.Booking_Id">
                                Reject Order
                            </button>
                        </div>

                        <div class="modal fade" id="rejectModal-@booking.Booking_Id" tabindex="-1"
                             aria-labelledby="rejectModalLabel-@booking.Booking_Id" aria-hidden="true">
                            <div class="modal-dialog">
                                <div class="modal-content">
                                    <form asp-action="RejectOrder" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@booking.Booking_Id" />
                                        <div class="modal-header">
                                            <h5 class="modal-title" id="rejectModalLabel-@booking.Booking_Id">Reject Order</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                        </div>
                                        <div class="modal-body">
                                            <p class="text-secondary mb-3">You are about to reject booking <strong>@booking.Booking_Reference</strong>. Please provide a reason.</p>
                                            <div class="mb-3">
                                                <label class="form-label fw-semibold">Rejection Reason <span class="text-danger">*</span></label>
                                                <textarea name="reason" class="form-control" rows="3" maxlength="200" required
                                                          placeholder="Enter the reason for rejection..."></textarea>
                                            </div>
                                        </div>
                                        <div class="modal-footer">
                                            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                                            <button type="submit" class="btn btn-danger">Confirm Rejection</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</section>
